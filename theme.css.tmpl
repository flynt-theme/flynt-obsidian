  /* Accent palette - for use in global CSS rules */
  --flynt-tx:    {{ .light.tx }};
  --flynt-tx2:   {{ .light.tx2 }};
  --flynt-tx5:   {{ .light.tx5 }};
  --flynt-amber: {{ .light.amber }};
  --flynt-delft: {{ .light.delft }};
