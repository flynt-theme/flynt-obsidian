  --code-important:   {{ .light.clay }};
  --code-keyword:     {{ .light.tx4 }};
  --code-operator:    {{ .light.rose }};
  --code-property:    {{ .light.tx3 }};
  --code-punctuation: {{ .light.tx }};
  --code-string:      {{ .light.delft }};
  --code-tag:         {{ .light.moss }};
